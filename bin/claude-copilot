#!/usr/bin/env bash
# claude-copilot — run Claude Code backed by GitHub Copilot / Codex via copilot-api.
#
# Isolated by design: it never edits your global ~/.claude config. It starts
# Claude Code with this tool's settings only, then copies through the one global
# setting that matters for UX parity: effortLevel.
#
# Subcommands:
#   claude-copilot                 start server (if needed) + open Claude Code
#   claude-copilot <args...>       same, passing args straight to `claude`
#   claude-copilot start           start the copilot-api server only
#   claude-copilot stop            stop the server
#   claude-copilot status          show server health
#   claude-copilot models          list all Copilot + Codex models for Claude Code
#   claude-copilot pick-model      interactively set the default Claude Code model
#   claude-copilot copilot-models  list raw Copilot models (/v1/models)
#   claude-copilot codex-models    list standalone Codex models (/codex/v1/models)
#   claude-copilot completion zsh  print shell completion (zsh/bash/fish)
#   claude-copilot usage           Copilot quota + local token usage (incl. Codex)
#   claude-copilot auth            run both OAuth logins (copilot + codex)
set -euo pipefail

CONFIG_DIR="${CLAUDE_COPILOT_HOME:-$HOME/.config/claude-copilot}"
PORT="${COPILOT_API_PORT:-4141}"
BASE_URL="http://localhost:${PORT}"
SETTINGS="${CONFIG_DIR}/settings.json"
MODEL_CATALOG="${CONFIG_DIR}/models.json"
LOG_FILE="${CONFIG_DIR}/server.log"
PID_FILE="${CONFIG_DIR}/server.pid"
DATA_DIR="${HOME}/.local/share/copilot-api"
USAGE_DB="${DATA_DIR}/copilot-api.sqlite"
GLOBAL_SETTINGS="${CLAUDE_COPILOT_SOURCE_SETTINGS:-$HOME/.claude/settings.json}"

# Make bun/npm global bins discoverable.
export PATH="$HOME/.bun/bin:$HOME/.local/bin:$PATH"

# Full isolation: start Claude through a clean process env and suppress the
# normal user/project/local setting sources. Without --setting-sources "", an
# existing ~/.claude/settings.json apiKeyHelper is still loaded and conflicts
# with this tool's ANTHROPIC_AUTH_TOKEN.
export CLAUDE_CONFIG_DIR="${CONFIG_DIR}"

mkdir -p "${CONFIG_DIR}"

die() { echo "[claude-copilot] $*" >&2; exit 1; }

have_copilot_api() { command -v copilot-api >/dev/null 2>&1; }

ensure_copilot_api() {
  have_copilot_api && return 0
  die "copilot-api not found. Install it with:  bun add -g @jeffreycao/copilot-api@latest  (or npm i -g)"
}

ensure_settings() {
  [ -f "${SETTINGS}" ] && return 0
  die "missing ${SETTINGS}. Run ./install.sh or copy settings.example.json there."
}

harden_settings() {
  python3 - "${SETTINGS}" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
data = json.loads(path.read_text())
changed = False

if data.get("apiKeyHelper") != "":
    data["apiKeyHelper"] = ""
    changed = True

env = data.setdefault("env", {})
model_migrations = {
    "ANTHROPIC_MODEL": {"claude-opus-4.6": "claude-opus-4.8"},
    "ANTHROPIC_DEFAULT_OPUS_MODEL": {"claude-opus-4.6": "claude-opus-4.8"},
    "ANTHROPIC_DEFAULT_SONNET_MODEL": {"claude-opus-4.6": "claude-sonnet-4.6"},
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": {"gpt-5-mini": "gpt-5.4-mini"},
}
for key, replacements in model_migrations.items():
    if env.get(key) in replacements:
        env[key] = replacements[env[key]]
        changed = True

if changed:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.replace(path)
PY
}

is_up() { curl -fsS "${BASE_URL}/v1/models" >/dev/null 2>&1; }

has_cli_option() {
  local option="$1"
  shift
  local arg
  for arg in "$@"; do
    case "${arg}" in
      "${option}"|"${option}="*) return 0 ;;
    esac
  done
  return 1
}

settings_env_value() {
  python3 - "${SETTINGS}" "$1" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
try:
    value = json.loads(path.read_text()).get("env", {}).get(key, "")
except Exception:
    value = ""
if value is not None:
    print(value)
PY
}

effective_effort() {
  if [ -n "${CLAUDE_COPILOT_EFFORT:-}" ]; then
    echo "${CLAUDE_COPILOT_EFFORT}"
    return 0
  fi

  python3 - "${GLOBAL_SETTINGS}" "${SETTINGS}" <<'PY'
import json
import pathlib
import sys

valid = {"low", "medium", "high", "xhigh", "max"}
for raw in sys.argv[1:]:
    path = pathlib.Path(raw).expanduser()
    if not path.exists():
        continue
    try:
        value = json.loads(path.read_text()).get("effortLevel")
    except Exception:
        continue
    if value in valid:
        print(value)
        break
PY
}

refresh_model_catalog() {
  python3 - "${BASE_URL}" "${MODEL_CATALOG}" <<'PY'
import datetime as dt
import json
import pathlib
import sys
import urllib.error
import urllib.request

base_url = sys.argv[1].rstrip("/")
out = pathlib.Path(sys.argv[2])

def load(path):
    url = f"{base_url}{path}"
    with urllib.request.urlopen(url, timeout=10) as response:
        data = json.load(response)
    items = data.get("data", data if isinstance(data, list) else [])
    return [item if isinstance(item, dict) else {"id": str(item)} for item in items]

def model_record(item, provider, source):
    upstream_id = str(item.get("id", ""))
    model_id = upstream_id
    if provider == "codex" and not upstream_id.startswith("codex/"):
        model_id = f"codex/{upstream_id}"

    capabilities = item.get("capabilities") or {}
    limits = capabilities.get("limits") or {}
    supports = capabilities.get("supports") or {}
    vision_limits = limits.get("vision") if isinstance(limits.get("vision"), dict) else {}
    kind = capabilities.get("type") or ("embedding" if "embedding" in model_id else "chat")
    if kind == "embeddings":
        kind = "embedding"

    record = {
        "id": model_id,
        "claude_model": model_id,
        "provider": provider,
        "source": source,
        "kind": kind,
        "name": item.get("name") or item.get("display_name") or upstream_id,
        "vendor": item.get("vendor") or item.get("owned_by") or "",
        "context_window": limits.get("max_context_window_tokens"),
        "max_prompt": limits.get("max_prompt_tokens"),
        "max_output": limits.get("max_output_tokens"),
        "max_non_streaming_output": limits.get("max_non_streaming_output_tokens"),
        "reasoning_effort": supports.get("reasoning_effort") or [],
        "min_thinking_budget": supports.get("min_thinking_budget"),
        "max_thinking_budget": supports.get("max_thinking_budget"),
        "vision": supports.get("vision"),
        "max_prompt_images": vision_limits.get("max_prompt_images"),
        "tool_calls": supports.get("tool_calls"),
        "parallel_tool_calls": supports.get("parallel_tool_calls"),
        "structured_outputs": supports.get("structured_outputs"),
        "streaming": supports.get("streaming"),
        "price_category": item.get("model_picker_price_category") or "",
    }
    if provider == "codex":
        record["upstream_id"] = upstream_id
    return record

models = []
errors = {}

try:
    for item in load("/v1/models"):
        models.append(model_record(item, "copilot", "/v1/models"))
except (OSError, urllib.error.URLError, json.JSONDecodeError) as exc:
    errors["copilot"] = str(exc)

try:
    for item in load("/codex/v1/models"):
        models.append(model_record(item, "codex", "/codex/v1/models"))
except (OSError, urllib.error.URLError, json.JSONDecodeError) as exc:
    errors["codex"] = str(exc)

payload = {
    "generated_at": dt.datetime.now(dt.UTC).isoformat(),
    "base_url": base_url,
    "models": sorted(models, key=lambda item: (item["kind"] != "chat", item["provider"], item["id"])),
}
if errors:
    payload["errors"] = errors

out.parent.mkdir(parents=True, exist_ok=True)
tmp = out.with_suffix(out.suffix + ".tmp")
tmp.write_text(json.dumps(payload, indent=2) + "\n")
tmp.replace(out)
PY
}

cmd_models() {
  refresh_model_catalog
  python3 - "${MODEL_CATALOG}" <<'PY'
import json
import sys

data = json.load(open(sys.argv[1]))

def tokens(value):
    if value in (None, ""):
        return "-"
    if isinstance(value, (int, float)):
        return f"{int(value / 1000)}k" if value >= 1000 else str(int(value))
    return str(value)

def effort(value):
    return "/".join(value) if value else "-"

print(f"generated_at: {data['generated_at']}")
print(f"base_url: {data['base_url']}")
print()
print("provider  kind       ctx    prompt  output  effort                         claude-code --model")
print("--------  ---------  -----  ------  ------  -----------------------------  -------------------")
for item in data["models"]:
    print(
        f"{item['provider']:<8}  "
        f"{item['kind']:<9}  "
        f"{tokens(item.get('context_window')):<5}  "
        f"{tokens(item.get('max_prompt')):<6}  "
        f"{tokens(item.get('max_output')):<6}  "
        f"{effort(item.get('reasoning_effort')):<29}  "
        f"{item['claude_model']}"
    )
if data.get("errors"):
    print()
    for provider, error in data["errors"].items():
        print(f"warning: failed to fetch {provider}: {error}")
PY
  echo
  echo "Use any chat model with: claude-copilot --model <id>"
  echo "Claude Code --effort accepts: low, medium, high, xhigh, max"
  echo "Catalog saved to: ${MODEL_CATALOG}"
}

cmd_pick_model() {
  refresh_model_catalog
  python3 - "${MODEL_CATALOG}" "${SETTINGS}" "$@" <<'PY'
import json
import pathlib
import sys

catalog_path = pathlib.Path(sys.argv[1])
settings_path = pathlib.Path(sys.argv[2])
args = sys.argv[3:]

catalog = json.loads(catalog_path.read_text())
settings = json.loads(settings_path.read_text())
env = settings.setdefault("env", {})
current = env.get("ANTHROPIC_MODEL", "")
models = [item for item in catalog["models"] if item.get("kind") == "chat"]
by_id = {item["claude_model"]: item for item in models}

def usage():
    print("Usage:")
    print("  claude-copilot pick-model")
    print("  claude-copilot pick-model <model-id>")
    print()
    print("Examples:")
    print("  claude-copilot pick-model gpt-5.5")
    print("  claude-copilot pick-model codex/gpt-5.4")

if args and args[0] in {"-h", "--help"}:
    usage()
    raise SystemExit(0)

if args:
    selected = args[0]
    if selected not in by_id:
        print(f"Unknown model: {selected}", file=sys.stderr)
        matches = [model for model in by_id if selected.lower() in model.lower()]
        if matches:
            print("Did you mean:", file=sys.stderr)
            for model in matches[:10]:
                print(f"  {model}", file=sys.stderr)
        raise SystemExit(2)
else:
    print("Select Claude Code model for claude-copilot")
    print(f"Current default: {current or '(unset)'}")
    print()
    for index, item in enumerate(models, 1):
        mark = " *" if item["claude_model"] == current else ""
        quota = "ChatGPT" if item["provider"] == "codex" else "Copilot"
        ctx = item.get("context_window")
        ctx_label = f"{int(ctx / 1000)}k" if isinstance(ctx, (int, float)) and ctx >= 1000 else "-"
        effort = "/".join(item.get("reasoning_effort") or []) or "-"
        print(f"{index:2d}. {item['claude_model']:<30} {item['provider']:<7} {quota:<7} ctx {ctx_label:<5} effort {effort}{mark}")
    print()
    try:
        raw = input("Choose number or model id (blank keeps current): ").strip()
    except EOFError:
        raw = ""
    if not raw:
        print("Model unchanged.")
        raise SystemExit(0)
    if raw.isdigit():
        index = int(raw)
        if index < 1 or index > len(models):
            print(f"Selection out of range: {raw}", file=sys.stderr)
            raise SystemExit(2)
        selected = models[index - 1]["claude_model"]
    else:
        selected = raw
        if selected not in by_id:
            print(f"Unknown model: {selected}", file=sys.stderr)
            raise SystemExit(2)

env["ANTHROPIC_MODEL"] = selected
tmp = settings_path.with_suffix(settings_path.suffix + ".tmp")
tmp.write_text(json.dumps(settings, indent=2) + "\n")
tmp.replace(settings_path)

item = by_id[selected]
quota = "ChatGPT" if item["provider"] == "codex" else "Copilot"
print(f"Default model set to: {selected} ({item['provider']}, {quota})")
print("Next launch will pass it to Claude Code as: --model " + selected)
PY
}

cmd_complete_commands() {
  printf '%s\n' \
    auth \
    start \
    stop \
    status \
    models \
    all-models \
    pick-model \
    select-model \
    model \
    copilot-models \
    codex-models \
    usage \
    completion
}

cmd_complete_models() {
  if is_up; then
    refresh_model_catalog >/dev/null 2>&1 || true
  fi
  [ -f "${MODEL_CATALOG}" ] || return 0
  python3 - "${MODEL_CATALOG}" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1]))
except Exception:
    raise SystemExit(0)

for item in data.get("models", []):
    if item.get("kind") == "chat":
        print(item["claude_model"])
PY
}

cmd_completion() {
  local shell="${1:-zsh}"
  case "${shell}" in
    zsh)
      cat <<'EOF'
#compdef claude-copilot

_claude_copilot() {
  local -a commands models
  commands=("${(@f)$(claude-copilot _complete-commands 2>/dev/null)}")

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return
  fi

  if [[ "${words[CURRENT-1]}" == "--model" || "${words[2]}" == "pick-model" || "${words[2]}" == "select-model" || "${words[2]}" == "model" ]]; then
    models=("${(@f)$(claude-copilot _complete-models 2>/dev/null)}")
    _describe 'model' models
    return
  fi

  _arguments \
    '--model[Claude Code model id]:model:->models' \
    '--effort[Claude Code effort level]:effort:(low medium high xhigh max)' \
    '*::arg:->args'

  case "$state" in
    models)
      models=("${(@f)$(claude-copilot _complete-models 2>/dev/null)}")
      _describe 'model' models
      ;;
  esac
}

_claude_copilot "$@"
EOF
      ;;
    bash)
      cat <<'EOF'
_claude_copilot_complete() {
  local cur prev words cword
  COMPREPLY=()
  if declare -F _get_comp_words_by_ref >/dev/null 2>&1; then
    _get_comp_words_by_ref -n : cur prev words cword
  else
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    words=("${COMP_WORDS[@]}")
    cword="${COMP_CWORD}"
  fi

  if [[ "${prev}" == "--model" || "${words[1]}" == "pick-model" || "${words[1]}" == "select-model" || "${words[1]}" == "model" ]]; then
    COMPREPLY=( $(compgen -W "$(claude-copilot _complete-models 2>/dev/null)" -- "${cur}") )
    return 0
  fi

  if [[ "${cword}" -eq 1 ]]; then
    COMPREPLY=( $(compgen -W "$(claude-copilot _complete-commands 2>/dev/null)" -- "${cur}") )
    return 0
  fi

  COMPREPLY=( $(compgen -W "--model --effort --permission-mode --help" -- "${cur}") )
}

complete -F _claude_copilot_complete claude-copilot
EOF
      ;;
    fish)
      cat <<'EOF'
complete -c claude-copilot -f -n 'not __fish_seen_subcommand_from (claude-copilot _complete-commands)' -a '(claude-copilot _complete-commands)'
complete -c claude-copilot -f -l model -d 'Claude Code model id' -a '(claude-copilot _complete-models)'
complete -c claude-copilot -f -l effort -d 'Claude Code effort level' -a 'low medium high xhigh max'
complete -c claude-copilot -f -n '__fish_seen_subcommand_from pick-model select-model model' -a '(claude-copilot _complete-models)'
EOF
      ;;
    *)
      die "unknown shell '${shell}'. Use: zsh, bash, or fish"
      ;;
  esac
}

start_server() {
  if is_up; then echo "[claude-copilot] server already up at ${BASE_URL}"; return 0; fi
  ensure_copilot_api
  echo "[claude-copilot] starting copilot-api on port ${PORT} ..."
  nohup copilot-api start --port "${PORT}" >"${LOG_FILE}" 2>&1 &
  echo $! > "${PID_FILE}"
  for _ in $(seq 1 30); do
    if is_up; then echo "[claude-copilot] up."; return 0; fi
    sleep 1
  done
  echo "[claude-copilot] server did not become healthy. Check ${LOG_FILE}" >&2
  echo "[claude-copilot] Most likely you are not logged in. Run:  claude-copilot auth" >&2
  return 1
}

stop_server() {
  if [ -f "${PID_FILE}" ]; then
    local p; p="$(cat "${PID_FILE}")"
    kill "${p}" 2>/dev/null && echo "[claude-copilot] stopped (pid ${p})." || echo "[claude-copilot] not running."
    rm -f "${PID_FILE}"
  else
    echo "[claude-copilot] no pidfile; server may be running in another terminal."
  fi
}

cmd_usage() {
  echo "[claude-copilot] Copilot quota (remaining):"
  curl -fsS "${BASE_URL}/usage" 2>/dev/null | python3 -c "import sys,json;d=json.load(sys.stdin);q=d.get('quota_snapshots',{});print('  plan:',d.get('copilot_plan'),'| reset:',d.get('quota_reset_date'));[print(f\"  {k}: {v.get('percent_remaining')}% remaining\"+(' (unlimited)' if v.get('unlimited') else '')) for k,v in q.items()]" 2>/dev/null || echo "  (server down or not logged in)"
  echo
  if [ -f "${USAGE_DB}" ] && command -v sqlite3 >/dev/null 2>&1; then
    echo "[claude-copilot] Local token usage by provider/model (incl. Codex):"
    sqlite3 -header -column "${USAGE_DB}" "SELECT COALESCE(provider_name,'copilot') AS provider, model, COUNT(*) AS reqs, SUM(input_tokens) AS in_tok, SUM(output_tokens) AS out_tok, SUM(total_tokens) AS total FROM token_usage_events GROUP BY provider_name, model ORDER BY total DESC;" 2>/dev/null
    echo
  fi
  echo "Note: standalone Codex (codex/* models) remaining quota lives on your ChatGPT plan,"
  echo "      not here. Check it at https://chatgpt.com account settings."
}

case "${1:-}" in
  _complete-commands) cmd_complete_commands; exit 0 ;;
  _complete-models)   cmd_complete_models; exit 0 ;;
  completion|completions)
    shift
    cmd_completion "${1:-zsh}"
    exit 0 ;;
  start)        start_server; exit $? ;;
  stop)         stop_server; exit 0 ;;
  status)       is_up && echo "[claude-copilot] UP at ${BASE_URL}" || echo "[claude-copilot] DOWN"; exit 0 ;;
  models|all-models)
    is_up || die "server down (claude-copilot start)"
    cmd_models
    exit 0 ;;
  pick-model|select-model|model)
    is_up || die "server down (claude-copilot start)"
    shift
    cmd_pick_model "$@"
    exit 0 ;;
  copilot-models) is_up || die "server down (claude-copilot start)"; curl -fsS "${BASE_URL}/v1/models"; exit 0 ;;
  codex-models) is_up || die "server down (claude-copilot start)"; curl -fsS "${BASE_URL}/codex/v1/models"; exit 0 ;;
  usage)        cmd_usage; exit 0 ;;
  auth)
    ensure_copilot_api
    echo "[claude-copilot] === GitHub Copilot login (device flow) ==="
    copilot-api auth login --provider copilot || true
    echo "[claude-copilot] === Codex / ChatGPT login (browser OAuth) ==="
    copilot-api auth login --provider codex || true
    exit 0 ;;
esac

ensure_settings
harden_settings
start_server
refresh_model_catalog

claude_args=(--setting-sources "" --settings "${SETTINGS}")
if ! has_cli_option "--model" "$@"; then
  model="${CLAUDE_COPILOT_MODEL:-$(settings_env_value ANTHROPIC_MODEL)}"
  if [ -n "${model}" ]; then
    claude_args+=(--model "${model}")
  fi
fi
if ! has_cli_option "--effort" "$@"; then
  effort="$(effective_effort)"
  if [ -n "${effort}" ]; then
    claude_args+=(--effort "${effort}")
  fi
fi
exec env -i \
  HOME="${HOME}" \
  USER="${USER:-}" \
  LOGNAME="${LOGNAME:-${USER:-}}" \
  SHELL="${SHELL:-/bin/zsh}" \
  TERM="${TERM:-xterm-256color}" \
  TMPDIR="${TMPDIR:-/tmp}" \
  PATH="${PATH}" \
  CLAUDE_CONFIG_DIR="${CONFIG_DIR}" \
  claude "${claude_args[@]}" "$@"
