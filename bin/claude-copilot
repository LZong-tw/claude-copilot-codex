#!/usr/bin/env bash
# claude-copilot — run Claude Code backed by GitHub Copilot / Codex via copilot-api.
#
# Isolated by design: it never edits your global ~/.claude config. It starts
# Claude Code with this tool's settings only, then copies through the one global
# setting that matters for UX parity: effortLevel.
#
# Subcommands:
#   claude-copilot                 start server (if needed) + open Claude Code
#   claude-copilot <args...>       same, passing args straight to `claude`
#   claude-copilot start           start the copilot-api server only
#   claude-copilot stop            stop the server
#   claude-copilot status          show server health
#   claude-copilot models          list all Copilot + Codex models for Claude Code
#   claude-copilot copilot-models  list raw Copilot models (/v1/models)
#   claude-copilot codex-models    list standalone Codex models (/codex/v1/models)
#   claude-copilot usage           Copilot quota + local token usage (incl. Codex)
#   claude-copilot auth            run both OAuth logins (copilot + codex)
set -euo pipefail

CONFIG_DIR="${CLAUDE_COPILOT_HOME:-$HOME/.config/claude-copilot}"
PORT="${COPILOT_API_PORT:-4141}"
BASE_URL="http://localhost:${PORT}"
SETTINGS="${CONFIG_DIR}/settings.json"
MODEL_CATALOG="${CONFIG_DIR}/models.json"
LOG_FILE="${CONFIG_DIR}/server.log"
PID_FILE="${CONFIG_DIR}/server.pid"
DATA_DIR="${HOME}/.local/share/copilot-api"
USAGE_DB="${DATA_DIR}/copilot-api.sqlite"
GLOBAL_SETTINGS="${CLAUDE_COPILOT_SOURCE_SETTINGS:-$HOME/.claude/settings.json}"

# Make bun/npm global bins discoverable.
export PATH="$HOME/.bun/bin:$HOME/.local/bin:$PATH"

# Full isolation: start Claude through a clean process env and suppress the
# normal user/project/local setting sources. Without --setting-sources "", an
# existing ~/.claude/settings.json apiKeyHelper is still loaded and conflicts
# with this tool's ANTHROPIC_AUTH_TOKEN.
export CLAUDE_CONFIG_DIR="${CONFIG_DIR}"

mkdir -p "${CONFIG_DIR}"

die() { echo "[claude-copilot] $*" >&2; exit 1; }

have_copilot_api() { command -v copilot-api >/dev/null 2>&1; }

ensure_copilot_api() {
  have_copilot_api && return 0
  die "copilot-api not found. Install it with:  bun add -g @jeffreycao/copilot-api@latest  (or npm i -g)"
}

ensure_settings() {
  [ -f "${SETTINGS}" ] && return 0
  die "missing ${SETTINGS}. Run ./install.sh or copy settings.example.json there."
}

harden_settings() {
  python3 - "${SETTINGS}" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
data = json.loads(path.read_text())
changed = False

if data.get("apiKeyHelper") != "":
    data["apiKeyHelper"] = ""
    changed = True

env = data.setdefault("env", {})
model_migrations = {
    "ANTHROPIC_MODEL": {"claude-opus-4.6": "claude-opus-4.8"},
    "ANTHROPIC_DEFAULT_OPUS_MODEL": {"claude-opus-4.6": "claude-opus-4.8"},
    "ANTHROPIC_DEFAULT_SONNET_MODEL": {"claude-opus-4.6": "claude-sonnet-4.6"},
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": {"gpt-5-mini": "gpt-5.4-mini"},
}
for key, replacements in model_migrations.items():
    if env.get(key) in replacements:
        env[key] = replacements[env[key]]
        changed = True

if changed:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.replace(path)
PY
}

is_up() { curl -fsS "${BASE_URL}/v1/models" >/dev/null 2>&1; }

has_cli_option() {
  local option="$1"
  shift
  local arg
  for arg in "$@"; do
    case "${arg}" in
      "${option}"|"${option}="*) return 0 ;;
    esac
  done
  return 1
}

settings_env_value() {
  python3 - "${SETTINGS}" "$1" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
try:
    value = json.loads(path.read_text()).get("env", {}).get(key, "")
except Exception:
    value = ""
if value is not None:
    print(value)
PY
}

effective_effort() {
  if [ -n "${CLAUDE_COPILOT_EFFORT:-}" ]; then
    echo "${CLAUDE_COPILOT_EFFORT}"
    return 0
  fi

  python3 - "${GLOBAL_SETTINGS}" "${SETTINGS}" <<'PY'
import json
import pathlib
import sys

valid = {"low", "medium", "high", "xhigh", "max"}
for raw in sys.argv[1:]:
    path = pathlib.Path(raw).expanduser()
    if not path.exists():
        continue
    try:
        value = json.loads(path.read_text()).get("effortLevel")
    except Exception:
        continue
    if value in valid:
        print(value)
        break
PY
}

refresh_model_catalog() {
  python3 - "${BASE_URL}" "${MODEL_CATALOG}" <<'PY'
import datetime as dt
import json
import pathlib
import sys
import urllib.error
import urllib.request

base_url = sys.argv[1].rstrip("/")
out = pathlib.Path(sys.argv[2])

def load(path):
    url = f"{base_url}{path}"
    with urllib.request.urlopen(url, timeout=10) as response:
        data = json.load(response)
    items = data.get("data", data if isinstance(data, list) else [])
    return [item.get("id") if isinstance(item, dict) else str(item) for item in items]

models = []
errors = {}

try:
    for model_id in load("/v1/models"):
        models.append({
            "id": model_id,
            "claude_model": model_id,
            "provider": "copilot",
            "source": "/v1/models",
            "kind": "embedding" if "embedding" in model_id else "chat",
        })
except (OSError, urllib.error.URLError, json.JSONDecodeError) as exc:
    errors["copilot"] = str(exc)

try:
    for upstream_id in load("/codex/v1/models"):
        model_id = upstream_id if upstream_id.startswith("codex/") else f"codex/{upstream_id}"
        models.append({
            "id": model_id,
            "claude_model": model_id,
            "provider": "codex",
            "upstream_id": upstream_id,
            "source": "/codex/v1/models",
            "kind": "chat",
        })
except (OSError, urllib.error.URLError, json.JSONDecodeError) as exc:
    errors["codex"] = str(exc)

payload = {
    "generated_at": dt.datetime.now(dt.UTC).isoformat(),
    "base_url": base_url,
    "models": sorted(models, key=lambda item: (item["kind"] != "chat", item["provider"], item["id"])),
}
if errors:
    payload["errors"] = errors

out.parent.mkdir(parents=True, exist_ok=True)
tmp = out.with_suffix(out.suffix + ".tmp")
tmp.write_text(json.dumps(payload, indent=2) + "\n")
tmp.replace(out)
PY
}

cmd_models() {
  refresh_model_catalog
  python3 - "${MODEL_CATALOG}" <<'PY'
import json
import sys

data = json.load(open(sys.argv[1]))
print(f"generated_at: {data['generated_at']}")
print(f"base_url: {data['base_url']}")
print()
print("provider  kind       claude-code --model")
print("--------  ---------  -------------------")
for item in data["models"]:
    print(f"{item['provider']:<8}  {item['kind']:<9}  {item['claude_model']}")
if data.get("errors"):
    print()
    for provider, error in data["errors"].items():
        print(f"warning: failed to fetch {provider}: {error}")
PY
  echo
  echo "Use any chat model with: claude-copilot --model <id>"
  echo "Catalog saved to: ${MODEL_CATALOG}"
}

start_server() {
  if is_up; then echo "[claude-copilot] server already up at ${BASE_URL}"; return 0; fi
  ensure_copilot_api
  echo "[claude-copilot] starting copilot-api on port ${PORT} ..."
  nohup copilot-api start --port "${PORT}" >"${LOG_FILE}" 2>&1 &
  echo $! > "${PID_FILE}"
  for _ in $(seq 1 30); do
    if is_up; then echo "[claude-copilot] up."; return 0; fi
    sleep 1
  done
  echo "[claude-copilot] server did not become healthy. Check ${LOG_FILE}" >&2
  echo "[claude-copilot] Most likely you are not logged in. Run:  claude-copilot auth" >&2
  return 1
}

stop_server() {
  if [ -f "${PID_FILE}" ]; then
    local p; p="$(cat "${PID_FILE}")"
    kill "${p}" 2>/dev/null && echo "[claude-copilot] stopped (pid ${p})." || echo "[claude-copilot] not running."
    rm -f "${PID_FILE}"
  else
    echo "[claude-copilot] no pidfile; server may be running in another terminal."
  fi
}

cmd_usage() {
  echo "[claude-copilot] Copilot quota (remaining):"
  curl -fsS "${BASE_URL}/usage" 2>/dev/null | python3 -c "import sys,json;d=json.load(sys.stdin);q=d.get('quota_snapshots',{});print('  plan:',d.get('copilot_plan'),'| reset:',d.get('quota_reset_date'));[print(f\"  {k}: {v.get('percent_remaining')}% remaining\"+(' (unlimited)' if v.get('unlimited') else '')) for k,v in q.items()]" 2>/dev/null || echo "  (server down or not logged in)"
  echo
  if [ -f "${USAGE_DB}" ] && command -v sqlite3 >/dev/null 2>&1; then
    echo "[claude-copilot] Local token usage by provider/model (incl. Codex):"
    sqlite3 -header -column "${USAGE_DB}" "SELECT COALESCE(provider_name,'copilot') AS provider, model, COUNT(*) AS reqs, SUM(input_tokens) AS in_tok, SUM(output_tokens) AS out_tok, SUM(total_tokens) AS total FROM token_usage_events GROUP BY provider_name, model ORDER BY total DESC;" 2>/dev/null
    echo
  fi
  echo "Note: standalone Codex (codex/* models) remaining quota lives on your ChatGPT plan,"
  echo "      not here. Check it at https://chatgpt.com account settings."
}

case "${1:-}" in
  start)        start_server; exit $? ;;
  stop)         stop_server; exit 0 ;;
  status)       is_up && echo "[claude-copilot] UP at ${BASE_URL}" || echo "[claude-copilot] DOWN"; exit 0 ;;
  models|all-models)
    is_up || die "server down (claude-copilot start)"
    cmd_models
    exit 0 ;;
  copilot-models) is_up || die "server down (claude-copilot start)"; curl -fsS "${BASE_URL}/v1/models"; exit 0 ;;
  codex-models) is_up || die "server down (claude-copilot start)"; curl -fsS "${BASE_URL}/codex/v1/models"; exit 0 ;;
  usage)        cmd_usage; exit 0 ;;
  auth)
    ensure_copilot_api
    echo "[claude-copilot] === GitHub Copilot login (device flow) ==="
    copilot-api auth login --provider copilot || true
    echo "[claude-copilot] === Codex / ChatGPT login (browser OAuth) ==="
    copilot-api auth login --provider codex || true
    exit 0 ;;
esac

ensure_settings
harden_settings
start_server
refresh_model_catalog

claude_args=(--setting-sources "" --settings "${SETTINGS}")
if ! has_cli_option "--model" "$@"; then
  model="${CLAUDE_COPILOT_MODEL:-$(settings_env_value ANTHROPIC_MODEL)}"
  if [ -n "${model}" ]; then
    claude_args+=(--model "${model}")
  fi
fi
if ! has_cli_option "--effort" "$@"; then
  effort="$(effective_effort)"
  if [ -n "${effort}" ]; then
    claude_args+=(--effort "${effort}")
  fi
fi
exec env -i \
  HOME="${HOME}" \
  USER="${USER:-}" \
  LOGNAME="${LOGNAME:-${USER:-}}" \
  SHELL="${SHELL:-/bin/zsh}" \
  TERM="${TERM:-xterm-256color}" \
  TMPDIR="${TMPDIR:-/tmp}" \
  PATH="${PATH}" \
  CLAUDE_CONFIG_DIR="${CONFIG_DIR}" \
  claude "${claude_args[@]}" "$@"
